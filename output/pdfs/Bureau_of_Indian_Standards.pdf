</section>
<script>
document.addEventListener("DOMContentLoaded", function () {
const video = document.getElementByClassName("standardsVideo");

if (video) {
video.muted = true;
setTimeout(() => {
video.pause();
console.log("Paused after short delay");
}, 10000); // Wait 10 seconds
}
});


</script>

<script>
"use strict";
// Select all slides and dots
const slides = document.querySelectorAll(".slide-2024");
const dotsContainer = document.querySelector(".dots");

// Loop through slides and set each slide's translateX
slides.forEach((slide, indx) => {
slide.style.transform = `translateX(${indx * 100}%)`;
// Create a dot for each slide
const dot = document.createElement("div");
dot.classList.add("dot");
dot.addEventListener("click", () => {
goToSlide(indx);
restartVideo();
});
dotsContainer.appendChild(dot);
});

// Current slide counter
let curSlide = 0;
// Maximum number of slides
let maxSlide = slides.length - 1;

// Function to move to a specific slide
function goToSlide(slideIndex) {
curSlide = slideIndex;
updateSlider();
}

// Function to update the slider based on the current slide
function updateSlider() {
// Move slides and update dots
slides.forEach((slide, indx) => {
slide.style.transform = `translateX(${100 * (indx - curSlide)}%)`;
});

// Update active dot
const dots = document.querySelectorAll(".dot");
dots.forEach((dot, indx) => {
dot.classList.toggle("active", indx === curSlide);
});
}

// Function to move to the next slide
function nextSlide() {
curSlide = (curSlide + 1) % slides.length;
updateSlider();
restartVideo();
}

// Function to move to the previous slide
function prevSlide() {
curSlide = (curSlide - 1 + slides.length) % slides.length;
updateSlider();
restartVideo();
}

// Select next and previous slide buttons
const nextBtn = document.querySelector(".btn-next");
const prevBtn = document.querySelector(".btn-prev");

// Add event listeners for next and previous buttons
nextBtn.addEventListener("click", nextSlide);
prevBtn.addEventListener("click", prevSlide);

// Autoplay functionality
const autoplayInterval = 32000; // Set the interval time in milliseconds (e.g., 3000ms = 3 seconds)
let autoplay;

// Function to start autoplay
function startAutoplay() {
autoplay = setInterval(nextSlide, autoplayInterval);
}

// Start autoplay when the page loads
startAutoplay();

// Stop autoplay when the mouse enters the slider container
const sliderContainer = document.querySelector(".slider-2024");
sliderContainer.addEventListener("mouseenter", () => clearInterval(autoplay));

// Resume autoplay when the mouse leaves the slider container
sliderContainer.addEventListener("mouseleave", () => startAutoplay());

// Restart video when it ends and move to the next slide
function restartVideo() {
const video = document.querySelector(".loop-video");
video.currentTime = 0;
video.play();
}

// Restart video when it ends initially
restartVideo();
</script>
<script>
"use strict";

function initializeSlider(containerClass, autoplayInterval) {
// Select slides and dots
const slides = document.querySelectorAll(`.${containerClass} .slideMobile-2024`);
const dotsContainer = document.querySelector(`.${containerClass} .dots`);
const nextBtn = document.querySelector(`.${containerClass} .btn-next-mobile`);
const prevBtn = document.querySelector(`.${containerClass} .btn-prev-mobile`);

// loop through slides and set each slide's translateX
slides.forEach((slide, indx) => {
slide.style.transform = `translateX(${indx * 100}%)`;
// Create a dot for each slide
const dot = document.createElement("div");
dot.classList.add("dot");
dot.addEventListener("click", () => goToSlide(indx));
dotsContainer.appendChild(dot);
});

// current slide counter
let curSlide = 0;
// maximum number of slides
let maxSlide = slides.length - 1;

// function to move to a specific slide
function goToSlide(slideIndex) {
curSlide = slideIndex;
updateSlider();
restartVideo();
}

// function to update the slider based on the current slide
function updateSlider() {
// move slides and update dots
slides.forEach((slide, indx) => {
slide.style.transform = `translateX(${100 * (indx - curSlide)}%)`;
});

// update active dot
const dots = document.querySelectorAll(`.${containerClass} .dot`);
dots.forEach((dot, indx) => {
dot.classList.toggle("active", indx === curSlide);
});
}

// function to move to the next slide
function nextSlide() {
curSlide = (curSlide + 1) % slides.length;
updateSlider();
restartVideo();
}

// function to move to the previous slide
function prevSlide() {
curSlide = (curSlide - 1 + slides.length) % slides.length;
updateSlider();
restartVideo();
}

// add event listeners for next and previous buttons
nextBtn.addEventListener("click", nextSlide);
prevBtn.addEventListener("click", prevSlide);

// autoplay functionality
const autoplay = setInterval(nextSlide, autoplayInterval);

// stop autoplay when mouse enters the slider container
const sliderContainer = document.querySelector(`.${containerClass}`);
sliderContainer.addEventListener("mouseenter", () => clearInterval(autoplay));

// resume autoplay when mouse leaves the slider container
sliderContainer.addEventListener("mouseleave", () => {
clearInterval(autoplay);
setInterval(nextSlide, autoplayInterval);
});

// Restart video when it ends initially
restartVideo();

// Restart video when it ends and move to the next slide
function restartVideo() {
const videos = document.querySelectorAll(`.${containerClass} .loop-video`);
videos.forEach(video => {
video.currentTime = 0;
video.play();
});
}
}

// Initialize the first slider
initializeSlider("sliderMobile-2024", 32000);
// Initialize more sliders if needed
</script>
<script type="text/javascript" src="https://www.bis.gov.in/wp-content/themes/bisnew/js/ui/jquery-ui.js"></script>
<script>  
$('#cat_icon').click(function () {  
$('#cat_icon').fadeIn(function () {
$('#categories').toggle('slide', {
direction: 'left'
}, 1000);
});
$('.panel_title_left').css('display','block'); 
$('#cat_icon').css('display','none');
}); 
$('.panel_title').click(function () {

$('.panel_title_left').css('display','none'); 
$('#cat_icon').css('display','block'); 
$('#cat_icon').fadeIn(function () {

$('#categories').toggle('slide', {
direction: 'left'
}, 1000);
});
}); 
</script>
<script>  
$('#cat_icon1').click(function () {  
$('#cat_icon1').fadeIn(function () {
$('#categories1').toggle('slide', {
direction: 'right'
}, 1000);
});
$('.panel_title_right').css('display','block'); 
$('#cat_icon1').css('display','none');
}); 
$('.panel_title1').click(function () {
$('.panel_title_right').css('display','none');
$('#cat_icon1').css('display','block'); 
$('#cat_icon1').fadeIn(function () {
$('#categories1').toggle('slide', {
direction: 'right'
}, 1000);
});
}); 
</script>

<script type="text/javascript" src="https://www.bis.gov.in/wp-content/themes/bisnew/js/slick.min.js"></script>
<script id="rendered-js" >
jQuery('.slider-for').slick({
slidesToShow: 1,
slidesToScroll: 1,
arrows: false,
dots: false,
focusOnSelect: true,
verticalSwiping: false,
autoplay: true,
autoplaySpeed: 3000,
asNavFor: '.slider-for' });

jQuery('.slider-nav').slick({
slidesToShow: 4,
slidesToScroll: 1,
vertical: true,
asNavFor: '.slider-for',
dots: false,
focusOnSelect: true,
verticalSwiping: true,
autoPlay: true,
responsive: [
{
breakpoint: 992,
settings: {
vertical: false } },


{
breakpoint: 768,
settings: {
vertical: false } },


{
breakpoint: 580,
settings: {
vertical: false,
slidesToShow: 3 } },


{
breakpoint: 380,
settings: {
vertical: false,
slidesToShow: 2 } }] });
// Toggle buttons
jQuery('.pause-slider').click(function () {
jQuery('.slider-for, .slider-nav').slick('slickPause');
jQuery('.pause-slider').hide();
jQuery('.play-slider').show();
});

jQuery('.play-slider').click(function () {
jQuery('.slider-for, .slider-nav').slick('slickPlay');
jQuery('.play-slider').hide();
jQuery('.pause-slider').show();
});
//# sourceURL=pen.js
</script>


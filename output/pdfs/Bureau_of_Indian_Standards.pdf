<script>
$(document).ready(function () {
// Show the overlay and popup frame
$("#custom-overlay").show();
$("#custom-popup").hide().fadeIn(1000);

// Close the popup when the close icon is clicked
$("#close-icon").on("click", function (e) {
e.preventDefault();
$("#custom-popup").fadeOut(1000);
$("#custom-overlay").fadeOut(1000);
});

// Close the popup when clicking outside the popup
$("#custom-overlay").on("click", function (e) {
e.preventDefault();
$("#custom-popup").fadeOut(1000);
$("#custom-overlay").fadeOut(1000);
});
});
</script>

<script type="text/javascript">
jQuery(window).load(function(){

jQuery(function(){
jQuery('.toggle-nav').click(function(){
toggleNav();
});
});

function toggleNav(){
if (jQuery('#site-wrapper').hasClass('show-nav')){
// Do things on Nav Close
jQuery('#site-wrapper').removeClass('show-nav');
} else{
// Do things on Nav Open
jQuery('#site-wrapper').addClass('show-nav');
}
//$('#site-wrapper').toggleClass('show-nav');
}

});

function myFunctionlist() {
var x = document.getElementById("myTopnavlist");
if (x.className === "topnavlist") {
x.className += " responsivelist";
} else {
x.className = "topnavlist";
}
}
</script>
<script>
document.addEventListener("DOMContentLoaded", function () {
const searchInput = document.getElementById("edit-keywords");

searchInput.addEventListener("input", function () {
// Block dangerous characters: ', ", <, >, ;, ../
this.value = this.value.replace(/['"<>;]|(\.\.\/)/g, "");
});
});
</script>
